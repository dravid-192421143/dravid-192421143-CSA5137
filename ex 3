def generate_matrix(key):
    key = key.upper().replace("J", "I")
    matrix = []
    used = set()

    # Add key letters to matrix
    for char in key:
        if char.isalpha() and char not in used:
            used.add(char)
            matrix.append(char)

    # Add remaining alphabets
    for char in "ABCDEFGHIKLMNOPQRSTUVWXYZ":  # J is excluded
        if char not in used:
            matrix.append(char)

    # Convert to 5x5 matrix
    return [matrix[i:i+5] for i in range(0, 25, 5)]


def prepare_text(text):
    text = text.upper().replace("J", "I")
    text = ''.join(filter(str.isalpha, text))
    
    prepared = ""
    i = 0
    while i < len(text):
        a = text[i]
        b = ''
        if i + 1 < len(text):
            b = text[i + 1]

        if a == b:
            prepared += a + "X"
            i += 1
        else:
            if b:
                prepared += a + b
                i += 2
            else:
                prepared += a + "X"
                i += 1
    return prepared


def find_position(matrix, char):
    for row in range(5):
        for col in range(5):
            if matrix[row][col] == char:
                return row, col


def encrypt_pair(matrix, a, b):
    row1, col1 = find_position(matrix, a)
    row2, col2 = find_position(matrix, b)

    if row1 == row2:  # Same row
        return matrix[row1][(col1 + 1) % 5] + matrix[row2][(col2 + 1) % 5]

    elif col1 == col2:  # Same column
        return matrix[(row1 + 1) % 5][col1] + matrix[(row2 + 1) % 5][col2]

    else:  # Rectangle
        return matrix[row1][col2] + matrix[row2][col1]


def playfair_encrypt(key, plaintext):
    matrix = generate_matrix(key)
    prepared_text = prepare_text(plaintext)
    ciphertext = ""

    for i in range(0, len(prepared_text), 2):
        ciphertext += encrypt_pair(matrix, prepared_text[i], prepared_text[i+1])

    return matrix, ciphertext


# ---- Main Program ----
key = input("Enter keyword: ")
plaintext = input("Enter plaintext: ")

matrix, ciphertext = playfair_encrypt(key, plaintext)

print("\n5x5 Matrix:")
for row in matrix:
    print(" ".join(row))

print("\nCiphertext:", ciphertext)